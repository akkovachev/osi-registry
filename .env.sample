# Required for POST/DELETE /v0.1/servers. Without it, those endpoints return 503.
# Generate one with: openssl rand -hex 32
ADMIN_API_KEY=
COMPOSE_PROJECT_NAME=mcp-osi-01  
APP_TIMEZONE=UTC
PROJECT_HOST_NAME=mcp-osi-01.objectsystems.com  
WEB_HOST_NAME=mcp-osi-01.objectsystems.com  
APP_ENV=production
